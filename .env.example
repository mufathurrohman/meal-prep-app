# AI Provider: "openrouter" (default), "anthropic", or "openai"
AI_PROVIDER=openrouter

# Your API key for the chosen provider
# Get your OpenRouter key at https://openrouter.ai/keys
AI_API_KEY=your-api-key-here

# Optional: override the default model
# OpenRouter default: deepseek/deepseek-chat-v3-0324:free
# Anthropic: claude-sonnet-4-20250514
# OpenAI: gpt-4o
# AI_MODEL=

# Supabase (get these from your Supabase project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
